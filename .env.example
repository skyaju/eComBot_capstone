# eComBot — environment variables
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments and are ignored.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# LLM / Model
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
MODEL_NAME=openrouter/google/gemini-2.5-flash
MODEL_TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# Agent
# ─────────────────────────────────────────────────────────────────────────────
AGENT_NAME=eComBot
AGENT_PERSONA=friendly
# Set to true to enable the ADK multi-agent system (ProductAgent, OrderAgent,
# KnowledgeAgent sub-agents under a root orchestrator)
MULTI_AGENT_MODE=false
TOOLS_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Session / Memory
# ─────────────────────────────────────────────────────────────────────────────
SESSION_ID_PREFIX=ecombot-session
APP_NAME=ecombot_app
USER_ID=default_user
# Session TTL in seconds (default: 24 hours)
SESSION_TTL_SECONDS=86400

# ─────────────────────────────────────────────────────────────────────────────
# Redis — Session storage
# Docker Compose default: redis://redis:6379/0
# Local dev override:     redis://localhost:6379/0
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL — Analytics / Audit / Customer Profiles
# Docker Compose default: uses service name "postgres"
# Local dev override:     postgresql://ecombot:ecombot_secret@localhost:5432/ecombot
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecombot:ecombot_secret@postgres:5432/ecombot
POSTGRES_PASSWORD=ecombot_secret

# ─────────────────────────────────────────────────────────────────────────────
# ChromaDB — Vector store for RAG
# Docker Compose default: uses service name "chromadb"
# Local dev override:     CHROMA_HOST=localhost
# ─────────────────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=ecombot_knowledge
# Set true to skip startup ingestion (you can run ingestion manually later)
SKIP_KNOWLEDGE_INGESTION=true

# ─────────────────────────────────────────────────────────────────────────────
# Knowledge base / mock data paths (relative to project root)
# ─────────────────────────────────────────────────────────────────────────────
MOCK_DATA_DIR=src/data
KNOWLEDGE_BASE_DIR=data/knowledge

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Container ports (host-side; change to avoid conflicts)
# ─────────────────────────────────────────────────────────────────────────────
ECOMBOT_PORT=8080
CHAINLIT_PORT=8001
REDIS_PORT=6379
POSTGRES_PORT=5432
CHROMA_PORT=8000

